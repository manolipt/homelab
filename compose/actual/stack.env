# Top-level domain for hosting Actual
DOMAIN=example.com

# App Storage Directory
SVC_STORAGE_DIR=/data/actual

# OpenID Configuration
ACTUAL_OPENID_CLIENT_ID=client_id_from_authentik
ACTUAL_OPENID_CLIENT_SECRET=client_secret_from_authentik
ACTUAL_OPENID_DISCOVERY_URL=openid_configuration_url_from_authentik
